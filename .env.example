# Frontend API URL (without trailing slash)
EXPO_PUBLIC_API_URL=your-backend-url.onrender.com

# Backend Configuration
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/jobportal?retryWrites=true&w=majority

# Cloudinary Configuration (for resume uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret